**/.cache/
**/.ipynb_checkpoints/
**/.temp/
**/.tmp/
**/.vs/
**/.vscode/
**/*.a
**/*.bin
**/*.dll
**/*.dylib
**/*.exe
**/*.lib
**/*.o
**/*.obj
**/*.out
**/*.root
**/*.so*
**/*.swp
**/GPATH
**/GRTAGS
**/GTAGS
**/out/
**/temp/
