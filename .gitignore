# ==============================================================================
# Build & IDE artifacts
# ==============================================================================
**/.cache/
**/.ipynb_checkpoints/
**/.temp/
**/.tmp/
**/.vs/
**/.vscode/
**/*.a
**/*.bin
**/*.dll
**/*.dylib
**/*.exe
**/*.lib
**/*.o
**/*.obj
**/*.out
**/*.root
**/*.so*
**/*.swp
**/GPATH
**/GRTAGS
**/GTAGS
**/out/
**/temp/
**/tmp/
**/build/

# ==============================================================================
# Log & backup files
# ==============================================================================
**/*.log
*~
.DS_Store

# ==============================================================================
# Musae-main: scripts
# Only keep Example1, Example2, and their direct dependencies.
# ==============================================================================
Musae-main/scripts/*
!Musae-main/scripts/Example1.*
!Musae-main/scripts/Example2*
!Musae-main/scripts/vis.mac
!Musae-main/scripts/Material.gdml
# Allow images used by docs (if any)
!Musae-main/scripts/pic/
Musae-main/scripts/pic/*

# ==============================================================================
# Musae-main: data
# Only keep STL models and flux tables needed by Example1/Example2.
# ==============================================================================
# Ignore everything under data/
Musae-main/data/*
# Allow the Stl_model and Flux_model subdirectories
!Musae-main/data/Stl_model/
!Musae-main/data/Flux_model/

# Stl_model: only the 6 STL files used by Example1 and Example2
Musae-main/data/Stl_model/*
!Musae-main/data/Stl_model/ConcreteWallWithCubeHole0p7_Unit_mm.stl
!Musae-main/data/Stl_model/ConcreteWall_Unit_mm.stl
!Musae-main/data/Stl_model/StellPlate_Unit_mm.stl
!Musae-main/data/Stl_model/Tianqin_MCMCTest_12_23_A_Unitmm.stl
!Musae-main/data/Stl_model/Tianqin_MCMCTest_12_23_B_Unitmm.stl
!Musae-main/data/Stl_model/Tianqin_MCMCTest_12_23_C_Unitmm.stl

# Flux_model: only the 2 CSV files used by Example1 and Example2
Musae-main/data/Flux_model/*
!Musae-main/data/Flux_model/Survival_to_Ecut_table_pmin0.csv
!Musae-main/data/Flux_model/Survival_to_Ecut_table_pmin3.csv

# ==============================================================================
# Musae-main: terrain
# Only keep the 2 CSV files needed by Example2.
# ==============================================================================
Musae-main/terrain/*
!Musae-main/terrain/SimBox_Nx2_Ny2.csv
!Musae-main/terrain/test_flatdata_Nx2_Ny2.csv

# ==============================================================================
# Musae-main: deprecated / non-public directories
# ==============================================================================
Musae-main/small_pro/
Musae-main/YT_patch/
Musae-main/src/app/analysis/BK/
Musae-main/src/app/analysis/projection_bk/

# ==============================================================================
# MuCT
# ==============================================================================
MuCT/*.ipynb
!MuCT/Example2_reconstruct.ipynb
!MuCT/Example2_visualize.ipynb
MuCT/*.py
MuCT/*.log
MuCT/*.html
MuCT/*.png
MuCT/*.sh
MuCT/cloudpoint/
MuCT/muCT/
MuCT/output/
MuCT/temp_frames/
MuCT/temp_frames_terrain/

# input: ignore everything except Terrain/SimBox_Nx2_Ny2.csv
MuCT/input/*
!MuCT/input/Terrain/
MuCT/input/Terrain/*
!MuCT/input/Terrain/SimBox_Nx2_Ny2.csv

# ==============================================================================
# Project-level exclusions
# ==============================================================================
CMakeSettings.json
document/doxygen/html/
document/doxygen/latex/
document/doxygen/man/
document/doxygen/rtf/
document/doxygen/xml/
install/
thirdparty/
